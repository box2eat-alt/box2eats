# Copy to .env and fill in from Supabase → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_or_anon_key

# Clover (set on Supabase, not in Vite — never expose CLOVER_PRIVATE_TOKEN to the browser)
# Dashboard → Project Settings → Edge Functions → Secrets, or CLI:
#   supabase secrets set CLOVER_PUBLIC_TOKEN=... CLOVER_PRIVATE_TOKEN=... CLOVER_MERCHANT_ID=...
# Deploy functions: npm run functions:deploy
